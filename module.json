{
  "id": "esheyw-transfer",
  "title": "esheyw Local Transfer Module",
  "description": "Sharing data across local worlds",
  "authors": [
    {
      "name": "Emmanuel Wineberg",
      "email": "esheyw@gmail.com",
      "discord": "@esheyw"
    }
  ],
  "version": "1.3.0",
  "compatibility": {
    "minimum": "11",
    "verified": "13.332"
  },
  "relationships": {},
  "flags": {
    "hotReload": {
      "extensions": ["css", "hbs", "json"]
    }
  },
  "packs": [
    {
      "name": "local-macros",
      "label": "Local Macros",
      "path": "packs/local-macros",
      "type": "Macro",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "local-journals",
      "label": "Local Journals",
      "banner": null,
      "path": "packs/local-journals",
      "type": "JournalEntry",
      "ownership": {
        "PLAYER": "OBSERVER",
        "TRUSTED": "INHERIT",
        "ASSISTANT": "OWNER",
        "NONE": "NONE"
      },
      "flags": {
        "core": {
          "foo": true
        }
      }
    },
    {
      "name": "local-pf2e-scenes",
      "label": "Local PF2e Scenes",
      "banner": "modules/esheyw-transfer/assets/blankbanner.webp",
      "path": "packs/local-pf2e-scenes",
      "type": "Scene",
      "system": "pf2e",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "local-pf2e-actors",
      "label": "Local PF2e Actors",
      "banner": "modules/esheyw-transfer/assets/blankbanner.webp",
      "path": "packs/local-pf2e-actors",
      "type": "Actor",
      "system": "pf2e",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "local-pf2e-items",
      "label": "Local PF2e Items",
      "banner": "modules/esheyw-transfer/assets/blankbanner.webp",
      "path": "packs/local-pf2e-items",
      "type": "Item",
      "system": "pf2e",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "name": "local-pf2e-actors2",
      "label": "Local PF2e Actors2",
      "banner": "modules/esheyw-transfer/assets/blankbanner.webp",
      "path": "packs/local-pf2e-actors2",
      "type": "Actor",
      "system": "pf2e",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    }
  ],
  "esmodules": ["src/esheyw-helpers.mjs"],
  "packFolders": [
    {
      "name": "Local Compendia",
      "sorting": "m",
      "color": "#af0d0d",
      "packs": [
        "local-pf2e-actors",
        "local-pf2e-items",
        "local-pf2e-scenes",
        "local-macros",
        "local-journals",
        "local-pf2e-actors2"
      ],
      "folders": []
    }
  ]
}
